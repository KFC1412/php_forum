# 应用配置
APP_NAME=Forum System
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# 数据库配置
DB_HOST=localhost
DB_NAME=forum
DB_USER=root
DB_PASS=
DB_PREFIX=forum_

# 存储配置
STORAGE_TYPE=mysql

# 邮件配置
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@forum.com
MAIL_FROM_NAME=Forum System

# 缓存配置
CACHE_DRIVER=file

# 会话配置
SESSION_LIFETIME=120

# 安全配置
APP_KEY=base64:JfK5f7G8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z
